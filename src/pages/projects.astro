---
import Layout from '@layouts/Layout.astro';

const allProjects = [{
	title: 'Project 1',
	description: 'This is a project made by Ritik Sahni.',
	link: '',
}, {
	title: 'Project 2',
	description: 'This is a project made by Ritik Sahni.',
	link: '',
}]
---

<Layout title="Ritik Sahni - About">
	<main class="font-quicksand font-light">
		<!-- Insert content. -->
		<h1>projects made by ritik.</h1>
		{allProjects.map((project, index) => {
			return (
				<div class="m-8">
					<h2>{project.title}</h2>
					<p>{project.description}</p>
				</div>
			)
		})}
	</main>
</Layout>
